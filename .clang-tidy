---
Checks: >
  -*,
  bugprone-*,
  cppcoreguidelines-*,
  performance-*,
  concurrency-*,
  modernize-*,
  readability-*,
  portability-*,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -readability-magic-numbers,
  -modernize-use-trailing-return-type

WarningsAsErrors: 'bugprone-*,performance-*,concurrency-*,cppcoreguidelines-interfaces-*'

CheckOptions:
  - key:             readability-identifier-naming.ClassCase
    value:           CamelCase
  - key:             readability-identifier-naming.VariableCase
    value:           lower_case
  - key:             readability-identifier-naming.MemberPrefix
    value:           m_

  - key:             performance-for-range-copy.WarnOnAllAutoCopy
    value:           true
  - key:             performance-move-const-arg.CheckTrivialTypes
    value:           true

---